    <mass value="0.293633"/>
    <inertia ixx="0.0009363160280724659" iyy="0.0012427366259646676" izz="0.0021596955477074225" ixy="-4.404300590613591e-06" iyz="-6.231179076946574e-07" ixz="-2.7979649296653862e-05"/>
  </inertial>
  <visual>
    <origin xyz="-0.00122918 -0.00019042 -0.12385555" rpy="0 0 0"/>
