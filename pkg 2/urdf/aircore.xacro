<xacro:include filename="$(find aircore_description)/urdf/aircore.trans" />
<xacro:include filename="$(find aircore_description)/urdf/aircore.gazebo" />

<link name="base_link">
  <inertial>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    <mass value="0.439225"/>
    <inertia ixx="0.0011138883819159162" iyy="0.0016599215740339746" izz="0.0027503826039219545" ixy="2.8249298632144927e-14" iyz="9.053609013843502e-08" ixz="8.451472135959193e-14"/>
  </inertial>
  <visual>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://aircore_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
    <material name="silver"/>
  </visual>
  <collision>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
    <geometry>
      <mesh filename="package://aircore_description/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
    </geometry>
  </collision>
</link>

