<launch>

<rosparam file="$(find aircore_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="aircore" args="left_wheel_wheel_joint_velocity_controller right_wheel_wheel_joint_velocity_controller joint_state_controller"/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/aircore/joint_states"/>
</node>
</launch>
