<?xml version="1.0"?>
<robot name="robot_with_rplidar_c1">
  <!--
    Example: Robot with RPlidar C1 Sensor
    로봇의 상단(top)에 센서를 마운트하는 예제
  -->

  <!-- 로봇 베이스 (예제: 원형 로봇 베이스) -->
  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.15" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1.0"/>
      </material>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="0.15" length="0.05"/>
      </geometry>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" 
               iyy="0.1" iyz="0.0" 
               izz="0.2"/>
    </inertial>
  </link>

  <!-- 센서 마운팅 브래킷 (선택사항) -->
  <link name="rplidar_mount">
    <visual>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    
    <collision>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" 
               iyy="0.00001" iyz="0.0" 
               izz="0.00001"/>
    </inertial>
  </link>

  <!-- 베이스에서 마운트로의 조인트 -->
  <joint name="base_to_rplidar_mount" type="fixed">
    <parent link="base_link"/>
    <child link="rplidar_mount"/>
    <!-- 로봇 상단 중앙에 마운트 -->
    <origin xyz="0 0 0.065" rpy="0 0 0"/>
  </joint>

  <!-- RPlidar C1 베이스 -->
  <link name="rplidar_c1_base">
    <visual>
      <geometry>
        <cylinder radius="0.0278" length="0.0413"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="black">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="0.0278" length="0.0413"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.11"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
               iyy="0.0001" iyz="0.0" 
               izz="0.0000425"/>
    </inertial>
  </link>

  <!-- 마운트에서 센서로의 조인트 -->
  <joint name="rplidar_mount_to_base" type="fixed">
    <parent link="rplidar_mount"/>
    <child link="rplidar_c1_base"/>
    <!-- 마운트 상단에 센서 배치 -->
    <origin xyz="0 0 0.02065" rpy="0 0 0"/>
  </joint>

  <!-- 레이저 스캔 프레임 -->
  <link name="rplidar_c1_laser">
    <inertial>
      <mass value="0.0"/>
      <inertia ixx="0.0" ixy="0.0" ixz="0.0" 
               iyy="0.0" iyz="0.0" 
               izz="0.0"/>
    </inertial>
  </link>

  <!-- 센서 중심에 레이저 프레임 배치 -->
  <joint name="rplidar_c1_base_to_laser" type="fixed">
    <parent link="rplidar_c1_base"/>
    <child link="rplidar_c1_laser"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- 휠 (예제용) -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" 
               iyy="0.001" iyz="0.0" 
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="revolute">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.12 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0" effort="0" velocity="0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <material name="black"/>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </collision>
    
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" 
               iyy="0.001" iyz="0.0" 
               izz="0.001"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="revolute">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.12 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0" upper="0" effort="0" velocity="0"/>
  </joint>

  <!-- 머티리얼 정의 -->
  <material name="blue">
    <color rgba="0.0 0.0 1.0 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <material name="gray">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>

</robot>
