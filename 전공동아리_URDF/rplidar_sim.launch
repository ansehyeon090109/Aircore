<?xml version="1.0"?>
<launch>
  <!--
    RPlidar C1 센서 시뮬레이션 Launch 파일
    Gazebo 시뮬레이터에서 RPlidar C1을 사용하는 예제
  -->

  <!-- ==================== 인자 정의 ==================== -->
  <arg name="paused" default="true" doc="Gazebo를 일시정지 상태로 시작"/>
  <arg name="use_sim_time" default="true" doc="시뮬레이션 시간 사용"/>
  <arg name="gui" default="true" doc="Gazebo GUI 표시"/>
  <arg name="headless" default="false" doc="헤드리스 모드"/>
  <arg name="debug" default="false" doc="디버그 모드"/>
  <arg name="verbose" default="true" doc="상세 출력"/>
  <arg name="world_name" default="empty.world" doc="사용할 월드"/>

  <!-- ==================== Gazebo 시작 ==================== -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(find gazebo_ros)/worlds/$(arg world_name)"/>
    <arg name="debug" value="$(arg debug)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="headless" value="$(arg headless)"/>
    <arg name="verbose" value="$(arg verbose)"/>
  </include>

  <!-- ==================== URDF 로드 ==================== -->
  <!-- 방법 1: 직접 URDF 파일 로드 -->
  <param name="robot_description"
         command="cat $(find your_package)/urdf/rplidar_c1_example.urdf"/>

  <!-- 방법 2: Xacro 파일 사용 (주석 처리) -->
  <!--
  <param name="robot_description"
         command="$(find xacro)/xacro $(find your_package)/urdf/rplidar_c1.urdf.xacro"/>
  -->

  <!-- ==================== 로봇 상태 발행 ==================== -->
  <node name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher"
        respawn="false"
        output="screen">
    <remap from="joint_states" to="joint_states"/>
  </node>

  <!-- ==================== Gazebo 모델 생성 ==================== -->
  <node name="urdf_spawner"
        pkg="gazebo_ros"
        type="spawn_model"
        respawn="false"
        output="screen"
        args="-urdf 
              -model robot 
              -param robot_description
              -x 0
              -y 0
              -z 0.1
              -R 0
              -P 0
              -Y 0"/>

  <!-- ==================== TF 브로드캐스터 ==================== -->
  <!-- base_link에서 센서까지의 정적 변환 -->
  <node pkg="tf" type="static_transform_publisher"
        name="base_rplidar_broadcaster"
        args="0 0 0.065 0 0 0 base_link rplidar_c1_laser 10">
    <param name="frame_id" value="base_link"/>
    <param name="child_frame_id" value="rplidar_c1_laser"/>
  </node>

  <!-- ==================== RViz 시각화 ==================== -->
  <node name="rviz"
        pkg="rviz"
        type="rviz"
        args="-d $(find your_package)/config/rplidar_config.rviz"
        required="true"
        respawn="true"/>

  <!-- ==================== 센서 토픽 퍼블리셔 (선택사항) ==================== -->
  <!-- 
    실제 RPlidar 드라이버 대신 시뮬레이션 센서 데이터 퍼블리시
    gazebo_ros_laser 플러그인 사용
  -->
  
  <!-- 
  <node name="laser_assembler"
        pkg="laser_assembler"
        type="assembler"
        respawn="false"
        output="screen">
    <remap from="cloud" to="assembled_cloud"/>
  </node>
  -->

  <!-- ==================== 조인트 상태 퍼블리셔 ==================== -->
  <node pkg="joint_state_publisher_gui"
        type="joint_state_publisher_gui"
        name="joint_state_publisher_gui"
        respawn="false"
        output="screen">
  </node>

  <!-- ==================== 로깅 설정 ==================== -->
  <env name="ROSCONSOLE_CONFIG_FILE"
       value="$(find your_package)/config/rosconsole.config"/>

</launch>
